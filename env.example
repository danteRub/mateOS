# Example environment configuration for mateOS installation.
# Copy this file to env.sh and fill in your own values.

export DISK="/dev/sdX"            # Target disk (e.g., /dev/sda)
export USERNAME="usuario"         # Username for the new user
export PASSWORD="cambia_esta"     # User password
export HOSTNAME="mi-host"         # Hostname of the system
export TIMEZONE="Europe/Madrid"   # Time zone
export KEYMAP="es"                # Keyboard layout
